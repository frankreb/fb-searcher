# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Facebook
FB_COOKIES_PATH=./cookies/fb_cookies.json

# Scraper Settings
SCRAPE_INTERVAL_MINUTES=30
HEADLESS=true
PROXY_URL=

# Database
DB_PATH=./data/fb-searcher.db

# Server
PORT=3000
NODE_ENV=production

# AI Filter (Codex CLI) — set AI_FILTER_ENABLED=true to activate
# Requires `codex` CLI installed and configured (https://github.com/openai/codex)
AI_FILTER_ENABLED=false
AI_FILTER_PROMPT=Only send me items that are genuine good deals. Skip spam, scams, overpriced items, or irrelevant posts. I want real furniture under $200 in good condition.

# Logging
LOG_LEVEL=info
